# Path to the sibling collector directory used in this replication package.
# Shared modules (data_models, artifact_config_loader, embedding_generator)
# are imported from that directory to avoid code duplication.
#
# The packaged layout uses ../collector by default.
COLLECTOR_REPO_PATH=../collector

# Optional API key used by notebooks 5, 6, and 7 for LLM-assisted
# interpretations and report narratives. Those steps can be skipped.
ANTHROPIC_API_KEY=
